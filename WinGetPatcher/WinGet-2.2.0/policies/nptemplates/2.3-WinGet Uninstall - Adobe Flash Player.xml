<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<RULES>
    <RULE APP_VERSION="9.1.4-791" CACHE_TTL="259200" CACHE_TTL_SYNCED="true" CLASSIFICATION="REG_STATUS" DESCRIPTION="UNINSTALL TEMPLATE - removes Adobe Flash Player from endpoints. Detects via 'Windows Applications Installed contains Flash'. Runs WingetUninstall.ps1 -PackageId &quot;Adobe.Flash&quot;. DISABLED by default at both policy and action levels. Adobe Flash Player reached EOL on December 31, 2020 - WinGet catalog coverage for legacy installs varies. If the uninstall fails, use the Inventory template (2.1) to confirm the actual WinGet package ID." ENABLED="false" ID="-1136081759310527003" NAME="WinGet Uninstall - Adobe Flash Player" NOT_COND_UPDATE="true" UPGRADE_PERFORMED="true">
        <GROUP_IN_FILTER/>
        <INACTIVITY_TTL TTL="0" USE_DEFAULT="true"/>
        <ADMISSION_RESOLVE_DELAY TTL="0" USE_DEFAULT="true"/>
        <MATCH_TIMING RATE="28800" SKIP_INACTIVE="true">
            <ADMISSION ALL="true"/>
        </MATCH_TIMING>
        <EXPRESSION EXPR_TYPE="SIMPLE">
            <!--Rule expression. Rule name is: WinGet Uninstall - Adobe Flash Player-->
            <!-- MAIN RULE CONDITION: Forescout-native "Windows Applications Installed" property.
                 Condition shape verified against a genuine console export (Forescout 8.5.2.2,
                 APP_VERSION 9.1.4-791): composite field comp_application, matched on the
                 app_name subfield. Replace VALUE2 with the display-name substring to match. -->
            <CONDITION EMPTY_LIST_VALUE="false" FIELD_NAME="comp_application" LABEL="Windows Applications Installed" LEFT_PARENTHESIS="0" LOGIC="AND" RET_VALUE_ON_UKNOWN="UNMATCH" RIGHT_PARENTHESIS="0">
                <FILTER COMP_FIELD_NAME="comp_application" FILTER_ID="8150739732574975003">
                    <SUB_FILTER CASE_SENSITIVE="false" HAS_VALUE="true" MEETS="true" SUB_FIELD_NAME="app_name" TYPE="contains">
                        <VALUE VALUE2="Flash"/>
                    </SUB_FILTER>
                </FILTER>
            </CONDITION>
        </EXPRESSION>
        <EXCEPTION NAME="ip" UNKNOWN_EVAL="UNMATCH"/>
        <EXCEPTION NAME="mac" UNKNOWN_EVAL="UNMATCH"/>
        <EXCEPTION NAME="nbthost" UNKNOWN_EVAL="UNMATCH"/>
        <EXCEPTION NAME="user" UNKNOWN_EVAL="UNMATCH"/>
        <EXCEPTION NAME="group" UNKNOWN_EVAL="UNMATCH"/>
        <ORIGIN NAME="CUSTOM"/>
        <UNMATCH_TIMING RATE="28800" SKIP_INACTIVE="true">
            <ADMISSION ALL="true"/>
        </UNMATCH_TIMING>
        <SUBNET address="::" prefix="0"/>
        <RANGE FROM="0.0.0.0" TO="255.255.255.255"/>
        <RULE_CHAIN>
            <INNER_RULE APP_VERSION="9.1.4-791" CACHE_TTL="259200" CACHE_TTL_SYNCED="true" CLASSIFICATION="REG_STATUS" DESCRIPTION="" ID="8422113115917751003" NAME="Uninstall Adobe Flash Player" NOT_COND_UPDATE="true" RECHECK_MAIN_RULE_DEF="true">
                <MATCH_TIMING RATE="28800" SKIP_INACTIVE="true">
                    <ADMISSION ALL="true"/>
                </MATCH_TIMING>
                <ACTION DISABLED="true" NAME="run_script">
                    <PARAM NAME="define_time_to_run" VALUE="false"/>
                    <PARAM NAME="script_howtorun_ac" VALUE="WingetUninstall.ps1 -PackageId &quot;Adobe.Flash&quot;"/>
                    <PARAM NAME="time_to_run" VALUE="1"/>
                    <PARAM NAME="script_interactive" VALUE="false"/>
                    <SCHEDULE>
                        <START Class="Immediately"/>
                        <OCCURENCE onStart="true"/>
                    </SCHEDULE>
                </ACTION>
            </INNER_RULE>
        </RULE_CHAIN>
        <REPORT_TABLES/>
    </RULE>
</RULES>
