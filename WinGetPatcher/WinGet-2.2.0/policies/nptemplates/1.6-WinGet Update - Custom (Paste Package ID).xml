<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<RULES>
    <RULE APP_VERSION="9.1.4-791" CACHE_TTL="259200" CACHE_TTL_SYNCED="true" CLASSIFICATION="REG_STATUS" DESCRIPTION="GENERIC UPDATE TEMPLATE - admin fills in the blanks. To use this template: (1) Copy a WinGet package ID from a host's 'WinGet Updates - Package IDs' property in Host Details. (2) Replace BOTH occurrences of [PASTE-PACKAGE-ID-HERE] below - once in the condition's Value, once in the action's Command line. (3) Rename this policy to include the app name (e.g., 'WinGet Update - Adobe Photoshop'). (4) Scope the policy to your target endpoints. (5) Enable the policy and the Run Script action. Wildcards: append '.*' for app families (e.g., 'Adobe.Photoshop.*' updates all Photoshop variants). Disabled by default. Will not fire until both the policy and the action are enabled." ENABLED="false" ID="-1136081759310526905" NAME="WinGet Update - Custom (Paste Package ID)" NOT_COND_UPDATE="true" UPGRADE_PERFORMED="true">
        <GROUP_IN_FILTER/>
        <INACTIVITY_TTL TTL="0" USE_DEFAULT="true"/>
        <ADMISSION_RESOLVE_DELAY TTL="0" USE_DEFAULT="true"/>
        <MATCH_TIMING RATE="28800" SKIP_INACTIVE="true">
            <ADMISSION ALL="true"/>
        </MATCH_TIMING>
        <EXPRESSION EXPR_TYPE="SIMPLE">
            <!--Rule expression. Rule name is: WinGet Update - Custom (Paste Package ID)-->
            <CONDITION EMPTY_LIST_VALUE="false" FIELD_NAME="connect_wingetpatcher_updates_info" LABEL="WinGet Updates Info" LEFT_PARENTHESIS="0" LOGIC="AND" RET_VALUE_ON_UKNOWN="UNMATCH" RIGHT_PARENTHESIS="0">
                <FILTER COMP_FIELD_NAME="connect_wingetpatcher_updates_info" FILTER_ID="8150739732574974178">
                    <SUB_FILTER CASE_SENSITIVE="false" HAS_VALUE="true" MEETS="true" SUB_FIELD_NAME="wingetpatcher_updates_apps" TYPE="contains">
                        <VALUE VALUE2="[PASTE-PACKAGE-ID-HERE]"/>
                    </SUB_FILTER>
                </FILTER>
            </CONDITION>
        </EXPRESSION>
        <EXCEPTION NAME="ip" UNKNOWN_EVAL="UNMATCH"/>
        <EXCEPTION NAME="mac" UNKNOWN_EVAL="UNMATCH"/>
        <EXCEPTION NAME="nbthost" UNKNOWN_EVAL="UNMATCH"/>
        <EXCEPTION NAME="user" UNKNOWN_EVAL="UNMATCH"/>
        <EXCEPTION NAME="group" UNKNOWN_EVAL="UNMATCH"/>
        <ORIGIN NAME="CUSTOM"/>
        <UNMATCH_TIMING RATE="28800" SKIP_INACTIVE="true">
            <ADMISSION ALL="true"/>
        </UNMATCH_TIMING>
        <SUBNET address="::" prefix="0"/>
        <RANGE FROM="0.0.0.0" TO="255.255.255.255"/>
        <RULE_CHAIN>
            <INNER_RULE APP_VERSION="9.1.4-791" CACHE_TTL="259200" CACHE_TTL_SYNCED="true" CLASSIFICATION="REG_STATUS" DESCRIPTION="" ID="8422113115917750905" NAME="Update Custom Package" NOT_COND_UPDATE="true" RECHECK_MAIN_RULE_DEF="true">
                <MATCH_TIMING RATE="28800" SKIP_INACTIVE="true">
                    <ADMISSION ALL="true"/>
                </MATCH_TIMING>
                <ACTION DISABLED="true" NAME="run_script">
                    <PARAM NAME="define_time_to_run" VALUE="false"/>
                    <PARAM NAME="script_howtorun_ac" VALUE="WingetUpdate.ps1 -PackageId &quot;[PASTE-PACKAGE-ID-HERE]&quot;"/>
                    <PARAM NAME="time_to_run" VALUE="1"/>
                    <PARAM NAME="script_interactive" VALUE="false"/>
                    <SCHEDULE>
                        <START Class="Immediately"/>
                        <OCCURENCE onStart="true"/>
                    </SCHEDULE>
                </ACTION>
            </INNER_RULE>
        </RULE_CHAIN>
        <REPORT_TABLES/>
    </RULE>
</RULES>
